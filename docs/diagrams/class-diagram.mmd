---
config:
  class:
    hideEmptyMembersBox: true
---
classDiagram
    direction LR

    namespace notif {
        class Notifiable:::infra {
            <<trait>>
            +notify(notif: Notification) Result~(), NotifyError~
        }
        class Notification:::entity {
            +String summary
            +Option~String~ body
            +Option~Urgency~ urgency
            +Option~Duration~ expire_time
            +Option~String~ app_name
            +Option~PathBuf~ icon
        }
        class Urgency:::entity {
            <<enum>>
            Low
            Normal
            Critical
        }
        class LinuxNotify:::infra {
            +new() LinuxNotify
            -get_args(notif: Notification) Vec~String~
        }
    }
    LinuxNotify --|> Notifiable
    Notification ..> Urgency
    Notifiable ..> Notification

    namespace model {
        class MemoryData:::entity {
            +u64 total_memory
            +u64 used_memory
            +u64 total_swap
            +u64 used_swap
        }
        class BatteryModel:::domain {
            -Arc~AtomicBool~ running
            +new(running: Option~Arc~AtomicBool~~) BatteryModel
            +publish_to~F~(callback: F) Result~(), ModelError~
            +stop()
        }
        class BatteryEvent:::entity {
            <<enum>>
            PercentageUpdate(u8)
            StateUpdate(BatteryState)
        }
        class BatteryState:::entity {
            <<enum>>
            Unknown
            Charging
            Discharging
            Empty
            Full
            PendingCharge
            PendingDischarge
        }
        class DiskModel:::domain {
            +new() DiskModel
            +get() sysinfo::Disks
        }
        class DiskEvent:::entity {
            +String name
            +PathBuf mount_point
            +u64 total_space
            +u64 available_space
        }
        class MemoryModel:::domain {
            +new() MemoryModel
            +get() MemoryData
        }
    }
    MemoryModel ..> MemoryData
    BatteryEvent ..> BatteryState

    namespace watch {
        class WatchSource:::service {
            -Arc~Config~ config
            -Arc~AtomicBool~ running
            -Arc~Battery~ battery
            -Arc~Disk~ disk
            -Arc~Memory~ memory
            +new(config: Arc~Config~, running: Arc~AtomicBool~) WatchSource
            +listen() Receiver~Result~WatchEvents~~
        }
        class WatchEvents:::entity {
            <<enum>>
            Battery(BatteryEvent)
            Disk(DiskEvent)
            Memory(MemoryData)
        }
        class WatchService:::service {
            -Arc~Config~ config
            -WatchSource source
            -Box~dyn Notifiable~ notifier
            -Arc~AtomicBool~ running
            +new(config: Arc~Config~, notifier: Box~dyn Notifiable~) WatchService
            +start()
            +stop()
        }
    }
    WatchService *-- WatchSource
    WatchService *-- Notifiable
    WatchService ..> Notification
    WatchSource *-- BatteryModel
    WatchSource *-- DiskModel
    WatchSource *-- MemoryModel
    WatchSource ..> WatchEvents
    WatchEvents ..> BatteryEvent
    WatchEvents ..> DiskEvent
    WatchEvents ..> MemoryData

    namespace app {
        class main:::app {
            +main()
        }
        class Config:::app {
            +BatteryConfig battery
            +MemoryConfig memory
            +DiskConfig disk
            +load() Result~Self, ConfigError~
        }
    }
    main ..> WatchService
    main ..> Config
    main ..> LinuxNotify

    classDef infra fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f,stroke-width:1.5px
    classDef domain fill:#dcfce7,stroke:#22c55e,color:#14532d,stroke-width:1.5px
    classDef service fill:#ffedd5,stroke:#f97316,color:#7c2d12,stroke-width:1.5px
    classDef app fill:#f3e8ff,stroke:#a855f7,color:#3b0764,stroke-width:1.5px
    classDef entity fill:#e0e7ff,stroke:#6366f1,color:#1e1b4b,stroke-width:1.5px

---
config:
  class:
    hideEmptyMembersBox: true
---
classDiagram
    direction LR

    namespace notif {
        class Notifiable {
            <<trait>>
            +notify(notif: Notification) Result~(), NotifyError~
        }
        class Notification {
            +String summary
            +Option~String~ body
            +Option~Urgency~ urgency
            +Option~Duration~ expire_time
            +Option~String~ app_name
            +Option~PathBuf~ icon
        }
        class Urgency {
            <<enum>>
            Low
            Normal
            Critical
        }
        class LinuxNotify {
            +new() LinuxNotify
            -get_args(notif: Notification) Vec~String~
        }
    }
    LinuxNotify --|> Notifiable
    Notification ..> Urgency
    Notifiable ..> Notification

    namespace model {
        class MemoryData {
            +u64 total_memory
            +u64 used_memory
            +u64 total_swap
            +u64 used_swap
        }
        class BatteryModel {
            -Arc~AtomicBool~ running
            +new(running: Option~Arc~AtomicBool~~) BatteryModel
            +publish_to~F~(callback: F) Result~(), ModelError~
            +stop()
        }
        class BatteryEvent {
            <<enum>>
            PercentageUpdate(u8)
            StateUpdate(BatteryState)
        }
        class BatteryState {
            <<enum>>
            Unknown
            Charging
            Discharging
            Empty
            Full
            PendingCharge
            PendingDischarge
        }
        class DiskModel {
            +new() DiskModel
            +get() sysinfo::Disks
        }
        class DiskEvent {
            +String name
            +PathBuf mount_point
            +u64 total_space
            +u64 available_space
        }
        class MemoryModel {
            +new() MemoryModel
            +get() MemoryData
        }
    }
    MemoryModel ..> MemoryData
    BatteryEvent ..> BatteryState

    namespace watch {
        class WatchSource {
            -Arc~Config~ config
            -Arc~AtomicBool~ running
            -Arc~Battery~ battery
            -Arc~Disk~ disk
            -Arc~Memory~ memory
            +new(config: Arc~Config~, running: Arc~AtomicBool~) WatchSource
            +listen() Receiver~Result~WatchEvents~~
        }
        class WatchEvents {
            <<enum>>
            Battery(BatteryEvent)
            Disk(DiskEvent)
            Memory(MemoryData)
        }
        class WatchService {
            -Arc~Config~ config
            -WatchSource source
            -Box~dyn Notifiable~ notifier
            -Arc~AtomicBool~ running
            +new(config: Arc~Config~, notifier: Box~dyn Notifiable~) WatchService
            +start()
            +stop()
        }
    }
    WatchService *-- WatchSource
    WatchService *-- Notifiable
    WatchService ..> Notification
    WatchSource *-- BatteryModel
    WatchSource *-- DiskModel
    WatchSource *-- MemoryModel
    WatchSource ..> WatchEvents
    WatchEvents ..> BatteryEvent
    WatchEvents ..> DiskEvent
    WatchEvents ..> MemoryData

    namespace app {
        class main {
            +main()
        }
        class Config {
            +BatteryConfig battery
            +MemoryConfig memory
            +DiskConfig disk
            +load() Result~Self, ConfigError~
        }
    }
    main ..> WatchService
    main ..> Config
    main ..> LinuxNotify
